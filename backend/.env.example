# E2B Sandbox Configuration
E2B_API_KEY=""

# E2B Custom Sandbox Templates
# For Next.js projects (built via e2b-templates/nextjs)
E2B_TEMPLATE_NEXTJS=""

# For React + Vite projects (built via e2b-templates/react-vite)
E2B_TEMPLATE_REACT_VITE=""

# LLM Provider Configuration
# Set either Google Gemini or OpenRouter API keys (or both)
GOOGLE_API_KEY=""

# Model configuration for different stages:
# - Blueprint generation: Complex planning, needs high quality (slower)
# - Code generation: File implementation, needs speed (faster)
#
# Available Gemini models:
# - gemini-3-flash-preview (fast, cost-effective)
# - gemini-3.1-pro-preview (1M input tokens, 65K output tokens, best quality, slower)
GEMINI_BLUEPRINT_MODEL="gemini-3.1-pro-preview"
GEMINI_GENERATION_MODEL="gemini-3-flash-preview"

# Backward compatibility: if above not set, falls back to GEMINI_MODEL
GEMINI_MODEL="gemini-3-flash-preview"

OPENROUTER_API_KEY=""
OPENROUTER_MODEL="moonshotai/kimi-k2.5"

# Database matches the default sqlite setup
DATABASE_URL="sqlite+aiosqlite:///./vibehub.db"

# LangSmith / Langchain Tracing (Optional)
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="vibehub"
