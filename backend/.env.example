# E2B Sandbox Configuration
E2B_API_KEY=""

# E2B Custom Sandbox Templates
# For Next.js projects (built via e2b-templates/nextjs)
E2B_TEMPLATE_NEXTJS=""

# For React + Vite projects (built via e2b-templates/react-vite)
E2B_TEMPLATE_REACT_VITE=""

# LLM Provider Configuration
# Set either Google Gemini or OpenRouter API keys (or both)
GOOGLE_API_KEY=""
GEMINI_MODEL="gemini-3-flash"

OPENROUTER_API_KEY=""
OPENROUTER_MODEL="moonshotai/kimi-k2.5"

# Database matches the default sqlite setup
DATABASE_URL="sqlite+aiosqlite:///./vibehub.db"

# LangSmith / Langchain Tracing (Optional)
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="vibehub"

# ============================================
# 实验性功能开关 (Experimental Features)
# 设置为 true 启用对应功能，默认全部关闭
# ============================================

# 实时代码编辑和热更新
# 允许用户在 Monaco Editor 中直接编辑代码，修改后实时同步到沙箱并热更新预览
FEAT_REALTIME_EDITOR="false"

# 多方案生成对比
# AI 生成 3 个不同风格的蓝图变体供用户选择，未选中的不消耗沙箱资源
FEAT_MULTI_BLUEPRINT="false"

# Strapi CMS 自动对接 (开发中)
# 在沙箱中自动启动 Strapi 后端，生成的前端代码直接对接 CMS API
FEAT_CMS_STRAPI="false"

# 一键部署到 Vercel (开发中)
# 用户点击按钮即可将生成项目部署为正式网站
FEAT_DEPLOY_VERCEL="false"

# 可视化点击编辑 (开发中)
# 在预览页面点击元素，用自然语言描述修改，AI 自动定位并修改对应代码
FEAT_VISUAL_EDITING="false"
