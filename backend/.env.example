# E2B Sandbox Configuration
E2B_API_KEY=""

# E2B Custom Sandbox Templates
# For Next.js projects (built via e2b-templates/nextjs)
E2B_TEMPLATE_NEXTJS=""

# For React + Vite projects (built via e2b-templates/react-vite)
E2B_TEMPLATE_REACT_VITE=""

# LLM Provider Configuration
# Set either Google Gemini or OpenRouter API keys (or both)
GOOGLE_API_KEY=""
GEMINI_MODEL="gemini-3-flash"

OPENROUTER_API_KEY=""
OPENROUTER_MODEL="moonshotai/kimi-k2.5"

# Database matches the default sqlite setup
DATABASE_URL="sqlite+aiosqlite:///./vibehub.db"

# LangSmith / Langchain Tracing (Optional)
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="vibehub"
